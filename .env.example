# ربات ۱ - کپی‌پست خودکار
BOT1_TOKEN=your_bot1_token_here

# ربات ۲ - ثبت سفارش
BOT2_TOKEN=your_bot2_token_here

# چنل مقصد شما
TARGET_CHANNEL=@your_channel_username

# آی‌دی عددی ادمین (از @userinfobot بگیر)
ADMIN_CHAT_ID=123456789

# کانال‌های منبع (با کاما جدا کن، بدون @)
SOURCE_CHANNELS=jobiranian,freelancers_ir,jobs_ir

# هر چند ثانیه کانال‌ها چک بشن (پیشنهاد: 300 = هر 5 دقیقه)
CHECK_INTERVAL_SECONDS=300

# درگاه پرداخت (بعداً پر کن — اختیاری)
PAYMENT_PROVIDER_TOKEN=

# قیمت‌ها (تومان)
PRICE_JOB_AD=150000
PRICE_FREELANCE_PROJECT=100000

# نام نمایشی کانال شما
CHANNEL_DISPLAY_NAME=کاریابی ایران
